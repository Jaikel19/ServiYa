CREATE TABLE Service (
  id TEXT NOT NULL PRIMARY KEY,
  name TEXT NOT NULL,
  cost REAL NOT NULL DEFAULT 0.0,
  duration TEXT NOT NULL DEFAULT '',
  description TEXT NOT NULL DEFAULT ''
);

selectAllServices:
SELECT id, name, cost, duration, description
FROM Service;

insertService:
INSERT OR REPLACE INTO Service(id, name, cost, duration, description)
VALUES (?, ?, ?, ?, ?);

deleteAllServices:
DELETE FROM Service;